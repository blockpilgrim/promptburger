# Server-side environment variables (set these in the Vercel dashboard:
# Project → Settings → Environment Variables). Never exposed to the browser.

# Required — the Anthropic API key that powers refinements for all visitors.
# Set a monthly spend limit on this key at https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-...

# Required for the /admin dashboard. Pick something long and random.
ADMIN_PASSWORD=

# Optional but recommended — Upstash Redis (free tier) for persistent usage
# tracking and reliable rate limiting. Provision via Vercel Marketplace
# (Storage → Upstash for Redis) and these are set automatically, or copy them
# from the Upstash console. Without Redis, limits and stats are in-memory
# only and reset whenever the serverless instance recycles.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
# (KV_REST_API_URL / KV_REST_API_TOKEN are also recognized.)

# Optional rate-limit overrides (defaults shown).
# RATE_LIMIT_PER_HOUR=10
# RATE_LIMIT_PER_DAY=30
# RATE_LIMIT_GLOBAL_PER_DAY=300
